{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "qwen3.5-plus",
    "base_url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
    "api_key_env": "DASHSCOPE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      },
      {
        "name": "MemSearch Updates",
        "url": "https://github.com/zilliztech/memsearch/commits.atom",
        "enabled": true,
        "category": "github-updates"
      },
      {
        "name": "Superpowers Updates",
        "url": "https://github.com/obra/superpowers/commits.atom",
        "enabled": true,
        "category": "github-updates"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/feed",
        "enabled": true,
        "category": "ai-news-zh"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech-analysis"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-open-source"
      },
      {
        "name": "r/MachineLearning",
        "url": "https://old.reddit.com/r/MachineLearning/hot/.rss?limit=15",
        "enabled": true,
        "category": "reddit-ml"
      },
      {
        "name": "r/LocalLLaMA",
        "url": "https://old.reddit.com/r/LocalLLaMA/hot/.rss?limit=15",
        "enabled": true,
        "category": "reddit-llm"
      },
      {
        "name": "GitHub Trending - Python",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/python.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "GitHub Trending - TypeScript",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/typescript.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "GitHub Trending - CUDA",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/cuda.xml",
        "enabled": true,
        "category": "github-trending"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "groups": [
    {
      "id": "headlines",
      "name": "头条速递",
      "default": true,
      "categories": ["tech-analysis", "hackernews", "ai-tools", "ai-news-zh", "ai-open-source", "reddit-ml", "reddit-llm", "reddit", "telegram", "github-activity", "linux-kernel"],
      "scoring": {
        "enabled": true,
        "prompt_file": "scoring_headlines.txt",
        "threshold": 7.0
      },
      "summary": {
        "prompt_file": null
      },
      "enrichment_mode": "full",
      "enrichment_prompt_file": null
    },
    {
      "id": "watched",
      "name": "关注动态",
      "categories": ["github-updates"],
      "scoring": {
        "enabled": false
      },
      "summary": {
        "prompt_file": null
      },
      "enrichment_mode": "summary_only",
      "enrichment_prompt_file": "enrichment_watched_summary.txt"
    },
    {
      "id": "github_trending",
      "name": "GitHub 热榜",
      "categories": ["github-trending"],
      "scoring": {
        "enabled": true,
        "prompt_file": "scoring_github_trending.txt",
        "threshold": 7.0
      },
      "summary": {
        "prompt_file": null
      },
      "enrichment_mode": "full",
      "enrichment_prompt_file": "enrichment_github_trending.txt"
    }
  ]
}