{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "qwen3.5-plus",
    "base_url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
    "api_key_env": "DASHSCOPE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      },
      {
        "name": "MemSearch Updates",
        "url": "https://github.com/zilliztech/memsearch/commits.atom",
        "enabled": true,
        "category": "github-updates"
      },
      {
        "name": "Superpowers Updates",
        "url": "https://github.com/obra/superpowers/commits.atom",
        "enabled": true,
        "category": "github-updates"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/feed",
        "enabled": true,
        "category": "ai-news-zh"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech-analysis"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-open-source"
      },
      {
        "name": "r/MachineLearning",
        "url": "https://old.reddit.com/r/MachineLearning/hot/.rss?limit=15",
        "enabled": true,
        "category": "reddit-ml"
      },
      {
        "name": "r/LocalLLaMA",
        "url": "https://old.reddit.com/r/LocalLLaMA/hot/.rss?limit=15",
        "enabled": true,
        "category": "reddit-llm"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  }
}